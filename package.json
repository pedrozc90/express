{
    "name": "express",
    "version": "0.0.0",
    "description": "express boilerplate",
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "start": "tsx src/index.ts",
        "start:dev": "tsx watch --env-file=.env src/index.ts",
        "type-check": "tsc --noEmit",
        "format": "prettier . --check",
        "format:fix": "prettier . --write",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "prisma:generate": "prisma generate",
        "prisma:clear": "prisma migrate reset --force",
        "prisma:migrate": "prisma migrate dev --name init",
        "prisma:migrate-new": "prisma migrate dev --create-only",
        "prepare": "sh .githooks/prepare.sh"
    },
    "keywords": [
        "express"
    ],
    "homepage": "https://github.com/pedrozc90/express#readme",
    "bugs": {
        "url": "https://github.com/pedrozc90/express/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pedrozc90/express.git"
    },
    "author": "pedrozc90+github@gmail.com",
    "license": "MIT",
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcryptjs": "^3.0.3",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.1.1",
        "pg": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/helmet": "^0.0.48",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.13.2",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^10.5.0",
        "globals": "^17.6.0",
        "jiti": "^2.7.0",
        "prettier": "^3.8.4",
        "prisma": "^7.8.0",
        "supertest": "^7.2.2",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vitest": "^4.1.8"
    }
}
