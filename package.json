{
    "name": "express",
    "version": "0.0.0",
    "description": "express + typescript restful api boilerplate",
    "main": "src/index.ts",
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "type-check": "tsc --noEmit",
        "start": "node --experimental-strip-types src/index.ts",
        "start:dev": "node --watch --experimental-strip-types --env-file=.env src/index.ts",
        "format": "prettier --check src/",
        "format:fix": "prettier --write src/",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "test": "vitest",
        "hooks": "simple-git-hooks"
    },
    "simple-git-hooks": {
        "pre-commit": ".githooks/pre-commit.sh"
    },
    "keywords": [
        "nodejs",
        "express",
        "typescript",
        "restful",
        "api",
        "boilerplate"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/pedrozc90/express.git"
    },
    "author": "pedrozc90 <pedrozc90+github@gmail.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/pedrozc90/express/issues"
    },
    "homepage": "https://github.com/pedrozc90/express#readme",
    "type": "module",
    "dependencies": {
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.1.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node-ts": "^23.6.4",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.13.1",
        "@types/supertest": "^7.2.0",
        "eslint": "^10.4.1",
        "globals": "^17.6.0",
        "jiti": "^2.7.0",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.8"
    },
    "engines": {
        "node": ">=24.x",
        "npm": ">=11.x"
    }
}